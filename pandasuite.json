{
  "version": "2.0.0",
  "main": "",

  "system": {
    "name": "Geolocation",
    "events": [
      {
        "id": "triggerMarker",
        "name": "GPS Detection",
        "locale_name": {
          "fr_FR": "Détection de la zone GPS"
        }
      }
    ],
    "markers": [
      {
        "hideSystemId": true,
        "enableSource": true,
        "params": [
          {
            "id": "center",
            "name": "Center",
            "locale_name": {
              "fr_FR": "Centre"
            },
            "type": "Coord",
            "value": {
              "lat": 48.861,
              "lng": 2.344
            },
            "bindable": true
          },
          {
            "id": "radius",
            "name": "Radius (meters)",
            "locale_name": { "fr_FR": "Rayon (mètres)" },
            "type": "Float",
            "bindable": true
          },
          {
            "id": "enter",
            "name": "Zone entry trigger",
            "locale_name": { "fr_FR": "Détection entrée de zone" },
            "type": "Boolean",
            "separator": true,
            "bindable": true
          },
          {
            "id": "exit",
            "name": "Zone exit trigger",
            "locale_name": { "fr_FR": "Détection sortie de zone" },
            "type": "Boolean",
            "bindable": true
          }
        ]
      }
    ],
    "defaults": {
      "markers": {
        "description": {
          "value": "[%s, %s]",
          "args": [
            {
              "key": "center.lat",
              "format": "0.0[0000]"
            },
            {
              "key": "center.lng",
              "format": "0.0[0000]"
            }
          ]
        }
      }
    }
  },

  "events": [
    {
      "id": "locationError",
      "name": "Geolocation Error",
      "locale_name": {
        "fr_FR": "Erreur de géolocalisation"
      }
    }
  ],

  "properties": [
    {
      "id": "apiKey",
      "name": "Google Maps API key",
      "type": "String",
      "activable": false,
      "value": "AIzaSyBtzf0Qa1brPE6V75WQfHzsxHTb11puFzM",
      "hidden": true
    },
    {
      "id": "detectionDistance",
      "name": "Default Detection Radius (meters)",
      "locale_name": {
        "fr_FR": "Distance de détection (mètres)"
      },
      "type": "Float",
      "value": 20
    }
  ],

  "queryable": {
    "coord": {
      "type": "Coord",
      "value": {
        "lat": 0,
        "lng": 0
      }
    },
    "__desc_coord": {
      "name": "Coordinates",
      "locale_name": {
        "fr_FR": "Coordonnées"
      }
    }
  }
}
